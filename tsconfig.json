{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "experimentalDecorators": false,
        "emitDecoratorMetadata": false
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "src/__tests__/**"]
}
